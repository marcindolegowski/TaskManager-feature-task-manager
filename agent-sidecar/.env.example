# Fallback Claude credentials, used only when the API does NOT pass a per-run
# credential. Per task, the .NET API resolves the developer's (or team's) own account
# and sends it in the /run body; that takes precedence over these. Use one of:
#   ANTHROPIC_API_KEY     - Console API key (pay-per-token, service identity)
#   CLAUDE_CODE_OAUTH_TOKEN - 1-year token from `claude setup-token` (subscription/SSO)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Token the sidecar uses to push the branch and open the draft PR (via `gh`).
GITHUB_TOKEN=ghp_...

# Port the sidecar listens on. The .NET API targets this via AGENT_SIDECAR_URL.
PORT=8787
